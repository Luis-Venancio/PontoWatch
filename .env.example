# ── Ponto Mais ──────────────────────────────────────────────
PM_API_TOKEN=seu_token_publico_aqui
PM_API_BASE_URL=https://api.pontomais.com.br/external_api/v1
# Token compartilhado configurado no cadastro do Webhook (Configurações do Ponto Mais).
# Se deixado em branco, o endpoint de webhook aceita requisições sem validar o header "token".
PONTOMAIS_WEBHOOK_TOKEN=

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=sua_service_role_key_aqui

# ── Job ──────────────────────────────────────────────────────
# Horário diário de execução (HH:MM, fuso America/Sao_Paulo)
JOB_HORA=06:00

# ── Notificações ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu@email.com
SMTP_PASS=sua_senha_app
EMAIL_RH=rh@empresa.com.br
